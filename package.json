{
    "name": "floating-web-notes",
    "private": true,
    "version": "0.3.2",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "build:dev": "NODE_ENV=development pnpm build",
        "build:screenshot": "vite build --mode screenshot",
        "lint": "biome check ./src --no-errors-on-unmatched",
        "lint:staged": "biome check ./src --staged --no-errors-on-unmatched --write",
        "screenshot": "pnpm build:screenshot && bunx http-server screenshots-set --port 6006 -o",
        "test": "pnpm build:dev && playwright test",
        "version": "bunx commit-and-tag-version --tag-force && pnpm build",
        "version:minor": "bunx commit-and-tag-version --tag-force --release-as minor && pnpm build",
        "version:major": "bunx commit-and-tag-version --tag-force --release-as major && pnpm build",
        "release": "mkdir releases/floating-web-notes-$(node -p \"require('./package.json').version\") && cd dist && zip -r \"../releases/floating-web-notes-$(node -p \"require('./manifest.json').version_name\")/floating-web-notes-$(node -p \"require('./manifest.json').version_name\").zip\" * && cd .. && git add . && git commit --amend --no-edit"
    },
    "dependencies": {
        "@base-ui/react": "1.6.0",
        "@doist/typist": "14.1.2",
        "emoji-regex": "^10.6.0",
        "linkifyjs": "^4.3.3",
        "lodash-es": "^4.18.1",
        "nanoid": "5.1.16",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-hotkeys-hook": "5.3.3",
        "react-rnd": "10.5.3",
        "turndown": "7.2.4",
        "use-debounce": "10.1.1",
        "zustand": "5.0.14"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@crxjs/vite-plugin": "2.7.0",
        "@playwright/test": "1.61.1",
        "@types/chrome": "0.2.0",
        "@types/node": "26.0.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/sanitize-html": "2.16.1",
        "@types/turndown": "5.0.6",
        "@vitejs/plugin-react": "6.0.3",
        "concurrently": "10.0.3",
        "typescript": "6.0.3",
        "vite": "8.1.0"
    }
}
